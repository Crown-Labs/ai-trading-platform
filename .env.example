# ── Required ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# OpenClaw gateway token (generated during first run)
# Get it from: http://localhost:18789 → Settings → Token
OPENCLAW_GATEWAY_TOKEN=

# ── Optional ─────────────────────────────────────────────────────
OPENCLAW_AGENT_ID=strategy-advisor

# Frontend API URL (leave empty for local dev, set for Docker prod)
# VITE_API_URL=http://localhost:4000
