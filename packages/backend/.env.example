# ── Database ──────────────────────────────────────────────────────
# Default port is 5433 (dev mode) — see docker-compose.dev.yml
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ai_trading_platform"

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── OpenClaw ──────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-token-here
OPENCLAW_AGENT_ID=trading-bot

# ── Auth (Google OAuth + JWT) ────────────────────────────────────
GOOGLE_CLIENT_ID=
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d
