{
  "name": "ai-trading-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @ai-trading/shared build && concurrently -n web,api \"yarn workspace @ai-trading/web dev\" \"yarn workspace @ai-trading/backend dev\"",
    "web": "yarn workspace @ai-trading/web",
    "backend": "yarn workspace @ai-trading/backend",
    "shared": "yarn workspace @ai-trading/shared",
    "postinstall": "yarn workspace @ai-trading/shared build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
